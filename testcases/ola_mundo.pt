# Olá Mundo em Pitão!

def ola_mundo():
    """Uma função simples que imprime uma saudação."""
    imprimir("Olá, Mundo!")

def saudacao(nome):
    """Sauda uma pessoa pelo nome."""
    se nome:
        imprimir(f"Olá, {nome}!")
    senao:
        imprimir("Olá, estranho!")

se __nome__ == "__principal__":
    ola_mundo()
    saudacao("Python")
    saudacao(Nulo)
